      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Bottom note"
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Video Card",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
