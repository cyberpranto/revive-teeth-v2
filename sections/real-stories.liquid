          "label": "Custom thumbnail (optional)"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer name"
        },
        {
          "type": "checkbox",
          "id": "show_verified",
          "label": "Show verified badge",
          "default": true
        },
        {
          "type": "text",
          "id": "verified_label",
          "label": "Verified badge text",
          "default": "Verified customer"
        }
      ]
    },
    {
      "type": "quote_card",
      "name": "Quote Card",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer name"
        },
        {
          "type": "checkbox",
          "id": "show_verified",
          "label": "Show verified badge",
          "default": true
        },
        {
          "type": "text",
          "id": "verified_label",
          "label": "Verified badge text",
          "default": "Verified customer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Real Stories",
      "blocks": [
        {
          "type": "video_card",
          "settings": {
            "customer_name": "Joshua",
            "quote": "\"I'm in sales, so confidence is everything, now I can feel myself smiling without even trying.\"",
            "show_verified": true
          }
        },
        {
          "type": "video_card",
          "settings": {
            "customer_name": "Connie",
            "quote": "\"I want to cry. I really do. I feel like I could go out and smile.\"",
            "show_verified": true
          }
        },
        {
          "type": "quote_card",
          "settings": {
            "customer_name": "Michelle",
            "quote": "\"I got so many compliments on my new smile, nobody could tell they were snap-in veneers. They look that natural.\"",
            "show_verified": true
          }
        },
        {
          "type": "quote_card",
          "settings": {
            "customer_name": "Lindsay",
