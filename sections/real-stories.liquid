<style>
  .tests-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .test-thumb {
    position: relative;
    aspect-ratio: 1 / 1; /* Square */
    overflow: hidden;
    /* border-radius: 24px; */
  }

  .test-thumb img,
  .test-thumb video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .test-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.25), rgba(0, 0, 0, 0.05));
    z-index: 2;
  }

  .testimonial-play {
    width: 72px;
    height: 72px;
    border: none;
    border-radius: 999px;
    background: #fff;
    color: #111;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .testimonial-play svg {
    width: 30px;
    height: 30px;
    display: block;
  }
</style>

<section class="warm" id="{{ section.settings.section_id }}">
  <div class="wrap">
    <div class="sect-head center">
      <div class="eyebrow">
        {{ section.settings.eyebrow }}
      </div>

      <h2 class="display" style="margin-top:14px">
        {{ section.settings.heading }}
      </h2>

      <p class="sub">
        {{ section.settings.subheading }}
      </p>
    </div>

    <div class="tests-grid">
      {% for block in section.blocks %}
        <article
          class="test-card"
          {{ block.shopify_attributes }}
        >
          <div class="test-thumb">
            <video
              class="testimonial-video"
              preload="metadata"
              playsinline
              {% if block.settings.thumbnail != blank %}
                poster="{{ block.settings.thumbnail | image_url: width: 1200 }}"
              {% endif %}
            >
              {% if block.settings.video != blank %}
                {% for source in block.settings.video.sources %}
                  <source
                    src="{{ source.url }}"
                    type="{{ source.mime_type }}"
                  >
                {% endfor %}
              {% endif %}
            </video>

            <div class="test-overlay">
              <button class="testimonial-play">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M8 5v14l11-7z"></path>
                </svg>
              </button>
            </div>

            <span class="tag">{{ block.settings.tag }}</span>
            <span class="rule"></span>
          </div>

          <div class="test-meta">
            {{ block.settings.meta }}
          </div>
        </article>
      {% endfor %}
    </div>

    <p class="tests-note">
      {{ section.settings.note }}
    </p>

    {% if section.settings.button_label != blank %}
      <div class="sect-cta-row">
        <button
          class="btn-primary scroll-buy"
          type="button"
        >
          {{ section.settings.button_label }}

          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </button>
      </div>
    {% endif %}
  </div>
</section>
<script>
  document.querySelectorAll('.testimonial-play').forEach((btn) => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.test-thumb');
      const video = card.querySelector('.testimonial-video');
      const overlay = card.querySelector('.test-overlay');

      video.controls = true;
      video.play();

      overlay.style.opacity = '0';
      overlay.style.pointerEvents = 'none';
    });
  });
</script>

{% schema %}
{
  "name": "Real Stories",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "default": "results"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Customer Stories"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real stories, arriving soon."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We're filming unscripted first-impression reactions from our launch customers, no incentives, no edits."
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Bottom Note",
      "default": "Video testimonials from our launch customers will appear here. We're recording real first-impression reactions, no scripts, no incentives."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Text",
      "default": "Start your smile"
    }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag",
          "default": "Confidence"
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta",
          "default": "Coming Soon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Real Stories",
      "blocks": [
        {
          "type": "story",
          "settings": {
            "tag": "Confidence",
            "meta": "Coming Soon"
          }
        },
        {
          "type": "story",
          "settings": {
            "tag": "Transformation",
            "meta": "Coming Soon"
          }
        },
        {
          "type": "story",
          "settings": {
            "tag": "The Process",
            "meta": "Coming Soon"
          }
        }
      ]
    }
  ]
}
{% endschema %}
