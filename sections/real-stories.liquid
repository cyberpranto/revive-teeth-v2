<section class="warm" id="{{ section.settings.section_id }}">
  <div class="wrap">
    <div class="sect-head center">
      {% if section.settings.eyebrow != blank %}
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="display" style="margin-top:14px">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="sub">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="tests-rail" id="testsRail-{{ section.id }}">
      {% for block in section.blocks %}
        {% if block.type == 'video_card' %}
          {%- assign vid_id = 'video-' | append: block.id -%}
          {%- assign overlay_id = 'overlay-' | append: block.id -%}

          <article class="test-card" {{ block.shopify_attributes }}>
            <div class="test-thumb">
              {% if block.settings.video != blank %}
                <video
                  id="{{ vid_id }}"
                  class="test-video"
                  preload="none"
                  playsinline
                  src="{{ block.settings.video.sources[1].url }}#t=0.5"
                  {% if block.settings.thumbnail != blank %}
                    poster="{{ block.settings.thumbnail | image_url: width: 800 }}"
                  {% else %}
                    poster="{{ block.settings.video.preview_image | image_url: width: 800 }}"
                  {% endif %}
                ></video>
              {% endif %}

              {% if block.settings.show_verified %}
                <span class="verified">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M5 12l5 5 9-11"></path>
                  </svg>
                  {{ block.settings.verified_label | default: 'Verified customer' }}
                </span>
              {% endif %}

              <div class="play" id="{{ overlay_id }}">
                <button class="play-btn" aria-label="Play {{ block.settings.customer_name | escape }}'s testimonial">
                  <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M6 4l14 8-14 8z"></path>
                  </svg>
                </button>
              </div>
            </div>
            <div class="test-cap">
              {% if block.settings.quote != blank %}
                <p class="test-quote">{{ block.settings.quote }}</p>
              {% endif %}
              {% if block.settings.customer_name != blank %}
                <p class="test-name">{{ block.settings.customer_name }}</p>
              {% endif %}
            </div>
          </article>

          <script>
            (function () {
              var v = document.getElementById('{{ vid_id }}');
              var overlay = document.getElementById('{{ overlay_id }}');
              if (!v || !overlay) return;
              overlay.addEventListener('click', async function () {
                overlay.classList.add('hidden');
                v.removeAttribute('poster');

                try {
                  await v.play();
                } catch (e) {
                  overlay.classList.remove('hidden');
                }
              });
              v.addEventListener('click', function () {
                if (!v.paused) v.pause();
              });
              v.addEventListener('play', function () {
                overlay.classList.add('hidden');
                v.removeAttribute('poster');
              });
              v.addEventListener('pause', function () {
                overlay.classList.remove('hidden');
              });
              v.addEventListener('ended', function () {
                overlay.classList.remove('hidden');
                v.currentTime = 0;
              });
            })();
          </script>

        {% elsif block.type == 'quote_card' %}
          <article class="test-card" {{ block.shopify_attributes }}>
            <div class="test-thumb is-quote">
              <svg class="qc-mark" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M10 7H6a3 3 0 0 0-3 3v7h7v-7H6.5A1.5 1.5 0 0 1 8 8.5V8a1 1 0 0 1 1-1zm10 0h-4a3 3 0 0 0-3 3v7h7v-7h-3.5A1.5 1.5 0 0 1 18 8.5V8a1 1 0 0 1 1-1z"></path>
              </svg>
              {% if block.settings.show_verified %}
                <span class="verified">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M5 12l5 5 9-11"></path>
                  </svg>
                  {{ block.settings.verified_label | default: 'Verified customer' }}
                </span>
              {% endif %}
            </div>
            <div class="test-cap">
              {% if block.settings.quote != blank %}
                <p class="test-quote">{{ block.settings.quote }}</p>
              {% endif %}
              {% if block.settings.customer_name != blank %}
                <p class="test-name">{{ block.settings.customer_name }}</p>
              {% endif %}
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>

    <div class="tests-dots" id="testsDots-{{ section.id }}" aria-hidden="true"></div>

    {% if section.settings.button_label != blank %}
      <div class="sect-cta-row">
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="btn-primary scroll-buy"
        >
          {{ section.settings.button_label }}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </a>
      </div>
    {% endif %}

    {% if section.settings.note != blank %}
      <p class="tests-note">{{ section.settings.note }}</p>
    {% endif %}
  </div>
</section>

<script>
  (function () {
    var rail = document.getElementById('testsRail-{{ section.id }}');
    var dotsWrap = document.getElementById('testsDots-{{ section.id }}');
    if (!rail || !dotsWrap) return;
    var cards = Array.from(rail.querySelectorAll('.test-card'));
    cards.forEach(function (card, i) {
      var b = document.createElement('button');
      b.type = 'button';
      b.setAttribute('aria-label', 'Go to testimonial ' + (i + 1));
      if (i === 0) b.classList.add('active');
      b.addEventListener('click', function () {
        card.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      });
      dotsWrap.appendChild(b);
    });
    var dots = Array.from(dotsWrap.children);
    var raf = null;
    rail.addEventListener(
      'scroll',
      function () {
        if (raf) return;
        raf = requestAnimationFrame(function () {
          raf = null;
          var center = rail.scrollLeft + rail.clientWidth / 2;
          var best = 0,
            bestDist = Infinity;
          cards.forEach(function (card, i) {
            var mid = card.offsetLeft + card.offsetWidth / 2;
            var d = Math.abs(mid - center);
            if (d < bestDist) {
              bestDist = d;
              best = i;
            }
          });
          dots.forEach(function (dot, i) {
            dot.classList.toggle('active', i === best);
          });
        });
      },
      { passive: true }
    );
  })();
</script>

{% schema %}
{
  "name": "Real Stories",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "default": "results"
