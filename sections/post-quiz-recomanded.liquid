                    </div>
                  </div>
                </div>
              </div>
            {% endcomment %}
          </div>
        </div>
      </div>
    </div>
  </section>
{% endif %}

<div class="sticky-bar" id="stickyBar" role="region" aria-label="Buy bar">
  <div class="sticky-inner">
    <div class="sb-info">
      <span id="sbInfoText">Upper &amp; Lower · $1,894</span>
      <span class="sb-sub">Revive Veneers · $100 quiz credit applied</span>
    </div>

    <button class="sb-cta scroll-buy">Reserve My Impression Kit</button>
  </div>
</div>
<script>
  function formatMoney(cents) {
    return '$' + (cents / 100).toLocaleString('en-US');
  }

  function applyConfig(button) {
    document.querySelectorAll('.arch-opt').forEach((opt) => {
      opt.classList.remove('sel');
      opt.setAttribute('aria-checked', 'false');
    });

    button.classList.add('sel');
    button.setAttribute('aria-checked', 'true');

    const realPrice = parseInt(button.dataset.price);

    document.getElementById('bpWas').textContent = formatMoney(realPrice);
    document.getElementById('bpNow').textContent = formatMoney(realPrice - 10000);

    const cta = document.getElementById('claimCTA');

    if (cta) {
      cta.dataset.variantId = button.dataset.variantId;
    }

    // Sticky Bar Update
    const sbInfo = document.getElementById('sbInfoText');

    if (sbInfo) {
      sbInfo.textContent = `${button.dataset.title} · ${formatMoney(realPrice - 10000)}`;
    }
  }
  document.querySelectorAll('.arch-opt').forEach((button) => {
    button.addEventListener('click', () => {
      applyConfig(button);
      const url = new URL(window.location);

      url.searchParams.set('arch', button.dataset.arch);

      history.replaceState({}, '', url);
    });
  });

  const params = new URLSearchParams(window.location.search);
  const arch = params.get('arch');

  if (arch) {
    const button = document.querySelector(`.arch-opt[data-arch="${arch}"]`);

    if (button) {
      applyConfig(button);
    }

    const offerSection = document.getElementById('offer');

    if (offerSection) {
      offerSection.scrollIntoView({
        behavior: 'smooth',
        block: 'start',
      });
    }
  }

  document.addEventListener('DOMContentLoaded', async function () {
    const email = localStorage.getItem('quiz_email');

    // URL e ?arch=lower thakle seta agey priority pabe (user just select korle),
    // na thakle quiz theke asha localStorage er arch use hobe
    const params = new URLSearchParams(window.location.search);
    const arch = params.get('arch') || localStorage.getItem('quiz_arch');

    if (!email) {
      console.warn('No quiz_email found on offer page');
      return;
    }

    try {
      const response = await fetch('https://quiz-funnel-worker.quiz-funnel-worker.workers.dev/quiz-complete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, arch }),
      });

      const data = await response.json();

      if (data.success) {
        localStorage.setItem('quiz_credit_code', data.code);
        localStorage.setItem('quiz_credit_expires_at', data.expiresAt);
        console.log('Credit code ready:', data.code);
      }
    } catch (err) {
      console.error('Offer page discount error:', err);
    }
  });

  // ⬇️ claimCTA — session/sessionStorage বাদ দিয়ে email দিয়ে কাজ করবে
  const claimCTA = document.getElementById('claimCTA');

  const checkbox = document.getElementById('termsAgreement');
  const termsError = document.getElementById('termsError');

  // শুরুতে disable
  claimCTA.disabled = true;

  // Checkbox change
  checkbox.addEventListener('change', function () {
    claimCTA.disabled = !this.checked;

    if (this.checked) {
      termsError.style.display = 'none';
    }
  });

  claimCTA.addEventListener('click', async function () {
    const variantId = this.dataset.variantId;

    console.log('Variant ID:', variantId);
    const email = localStorage.getItem('quiz_email');

    if (!email) {
      alert('Something went wrong — please retake the quiz.');
      return;
    }

    this.disabled = true;
    this.innerHTML = 'Preparing Checkout...';

    try {
      // 1. AGE cart e item add koro — discount link hit korar age
      // cart e item thakte hobe, nahole apply hoy na (age ei problem tai hoyechilo)
      await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          items: [{ id: variantId, quantity: 1 }],
        }),
      });

      const cart = await fetch('/cart.js').then((r) => r.json());

      console.log(cart);
      console.log(cart.item_count);
      console.log(cart.items);

      const acceptedAt = new Date().toISOString();

      await fetch('/cart/update.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          attributes: {
            terms_accepted: 'Yes',
            terms_accepted_at: acceptedAt,
            customer_email: email,
            accepted_from: 'Offer Page',
          },
        }),
      });

      // 2. EKHON worker theke valid discount code niye checkout e jao
      const res = await fetch('https://quiz-funnel-worker.quiz-funnel-worker.workers.dev/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      const data = await res.json();

      console.log(data.redirectUrl);

      if (!data.success) {
        throw new Error('Checkout failed');
      }

      window.location.href = data.redirectUrl;
    } catch (err) {
      console.error(err);

      this.disabled = false;
      this.innerHTML = originalText;

      alert('Something went wrong.');
    }
  });
</script>

