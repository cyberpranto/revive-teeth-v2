<style>
      .terms-label {
      display: flex;
      gap:16px;
      justify-content:flex-start;
      align-items: flex-start;
      margin-top:16px;
    }

    .buy-reassure-2 {
        text-align: left;
        font-size: 13px;
        color: var(--muted);
        line-height: 1.5;
        display: flex;
        gap: 8px;
        align-items: flex-start;
        justify-content: center;
      }

      .buy-reassure-2  a {
        text-decoration: underline;
        color: (--ink);
      }
      #claimCTA:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

{% assign product = section.settings.product %}
{% if section.settings.product == blank %}
  <p>Please select a product.</p>

{% else %}
  <section class="sec-cream" id="order" data-screen-label="Buy box">
    <div class="wrap">
      <div class="sec-intro center reveal">
        {% if section.settings.eyebrow != blank %}
          <span class="eyebrow">
            {{ section.settings.eyebrow }}
          </span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="dl">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <p class="lead">
            {{ section.settings.description }}
          </p>
        {% endif %}
      </div>

      <div class="reveal">
        <div class="pdp">
          <div class="pdp-gallery">
            <div class="gallery-main" id="galMain">
              <img
                src="{{ product.featured_image | image_url: width: 1200 }}"
                alt="{{ product.featured_image.alt }}"
                width="100"
                height="100"
              >
            </div>

            <div class="thumbs" id="thumbs">
              {% for image in product.images %}
                <button
                  class="thumb {% if forloop.first %}active{% endif %}"
                  data-image="{{ image | image_url: width: 1200 }}"
                  data-alt="{{ image.alt | escape }}"
                  aria-label="{{ image.alt | escape }}"
                >
                  <img
                    src="{{ image | image_url: width: 200 }}"
                    alt="{{ image.alt | escape }}"
                    width="100"
                    height="100"
                  >
                </button>
              {% endfor %}
            </div>
          </div>
          <div class="pdp-panel">
            <div class="rec-badge">
              {% if section.settings.badge_icon != blank %}
                {{ section.settings.badge_icon }}
              {% else %}
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M5 12l5 5 9-11"/>
                </svg>
              {% endif %}

              {{ section.settings.badge_text }}
            </div>

            <div class="buy-label">Configuration <span>· Choose one</span></div>

            <div
              class="arch-opts"
              role="radiogroup"
              aria-label="Configuration"
            >
              {% for variant in product.variants %}
                {% assign title = variant.title | downcase %}

                {% if title contains 'upper & lower' or title contains 'both' %}
                  {% assign arch = 'both' %}
                {% elsif title contains 'upper' %}
                  {% assign arch = 'upper' %}
                {% elsif title contains 'lower' %}
                  {% assign arch = 'lower' %}
                {% endif %}
                <button
                  class="arch-opt {% if forloop.last %}sel{% endif %}"
                  role="radio"
                  data-key="{{ variant.title | handle }}"
                  aria-checked="{% if forloop.last %}true{% else %}false{% endif %}"
                  data-variant-id="{{ variant.id }}"
                  data-price="{{ variant.price }}"
                  data-title="{{ variant.title }}"
                  tabindex="0"
                  data-arch="{{ arch }}"
                >
                  <span class="ao-check">
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M5 12l5 5 9-11"></path>
                    </svg>
                  </span>

                  {% if title contains 'upper & lower' or title contains 'upper and lower' or title contains 'both' %}
                    <span class="ao-badge">Most Popular</span>

                    <svg
                      class="arch-ico"
                      viewBox="0 0 60 40"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M4 16 C 8 0, 52 0, 56 16"></path>
                      <path d="M4 24 C 8 40, 52 40, 56 24"></path>
                    </svg>

                  {% elsif title contains 'upper' %}
                    <svg
                      class="arch-ico"
                      viewBox="0 0 60 32"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M4 22 C 8 6, 52 6, 56 22"></path>
                      <path
                        d="M12 12 L12 19 M20 9 L20 18 M30 7.5 L30 17.5 M40 9 L40 18 M48 12 L48 19"
                        stroke-width="1.6"
                      ></path>
                    </svg>

                  {% elsif title contains 'lower' %}
                    <svg
                      class="arch-ico"
                      viewBox="0 0 60 32"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M4 10 C 8 26, 52 26, 56 10"></path>
                      <path
                        d="M12 20 L12 13 M20 23 L20 14 M30 24.5 L30 14.5 M40 23 L40 14 M48 20 L48 13"
                        stroke-width="1.6"
                      ></path>
                    </svg>

                  {% else %}
                    <svg
                      class="arch-ico"
                      viewBox="0 0 60 32"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M4 10 C 8 26, 52 26, 56 10"></path>
                      <path
                        d="M12 20 L12 13 M20 23 L20 14 M30 24.5 L30 14.5 M40 23 L40 14 M48 20 L48 13"
                        stroke-width="1.6"
                      ></path>
                    </svg>
                  {% endif %}

                  <div>
                    <div class="ao-name">{{ variant.title }}</div>
                    <div class="ao-price">
                      <s>{{ variant.price | money_without_trailing_zeros }}</s>
                      {{- variant.price | minus: 10000 | money_without_trailing_zeros }}
                    </div>

                    {% if title contains 'upper & lower' or title contains 'upper and lower' or title contains 'both' %}
                      <div class="ao-save">Save $600 vs. two single arches at regular price.</div>
                    {% endif %}
                  </div>
                </button>
              {% endfor %}
            </div>
            <div class="price-anchor">
              <p>
                {{ section.settings.quote }}
              </p>

              <span class="pa-attr">
                {{ section.settings.quote_author }}
              </span>
            </div>

            <div class="buy-price">
              <div class="bp-line">
                <span class="bp-was" id="bpWas">$1,994</span>
                <span class="bp-now" id="bpNow">$1,894</span>
              </div>

              <div class="bp-credit">
                {% if section.settings.credit_icon != blank %}
                  {{ section.settings.credit_icon }}
                {% else %}
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect x="3" y="8" width="18" height="4" rx="1"></rect>
                    <path d="M5 12v9h14v-9"></path>
                    <path d="M12 8v13"></path>
                  </svg>
                {% endif %}

                {{ section.settings.credit_text }}
              </div>

              <div class="bp-fine">
                {{ section.settings.fine_text }}
              </div>
            </div>

            <div class="buy-stock"><span class="dot"></span>{{ section.settings.stock_text }}</div>
            <div class="terms-agreement">
              <label class="terms-label">
                <input
                  type="checkbox"
                  id="termsAgreement"
                  name="termsAgreement"
                >

                <span class="buy-reassure-2">
                  <p>
                    I have read and agree to the
                    <a href="/pages/terms-of-service" target="_blank" rel="noopener"> Terms of Services </a>, including
                    the Binding Arbitration Agreement and Class Action Waiver in Section 15, the
                    <a href="/pages/privacy-policy" target="_blank" rel="noopener"> Privacy Policy </a>, and the
                    <a href="/pages/refund-remake-returns-policy" target="_blank" rel="noopener">
                      Refund, Remake & Returns Policy </a
                    >.
                  </p>
                </span>
              </label>

              <p
                id="termsError"
                style="display:none;color:#d32f2f;font-size:14px;margin-top:8px;"
              >
                Please accept the terms before continuing.
              </p>
            </div>
            <button class="btn btn-full claim-cta" data-variant-id="" id="claimCTA" disabled>
              {{ section.settings.button_text }}

              {% if section.settings.button_icon != blank %}
                {{ section.settings.button_icon }}

              {% else %}
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M5 12h14M13 6l6 6-6 6"></path>
                </svg>
              {% endif %}
            </button>
            <div class="buy-reassure">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12l5 5 9-11"></path>
              </svg>
              Made to your mouth. We remake the fit free, up to twice. Full refund any time before production begins.
            </div>
            <div class="trust-pills">
              {% for block in section.blocks %}
                {% case block.type %}
                  {% when 'trust_pill' %}
                    <span class="tp" {{ block.shopify_attributes }}>
                      {% if block.settings.icon_svg != blank %}
                        {{ block.settings.icon_svg }}

                      {% else %}
                        <svg
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.9"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"></path>
                          <path d="M8.5 12.5l2.5 2.5L16 10"></path>
                        </svg>
                      {% endif %}

                      {{ block.settings.text }}
                    </span>
                {% endcase %}
              {% endfor %}
            </div>

            <div class="pay-row">
              {% for block in section.blocks %}
                {% case block.type %}
                  {% when 'payment_method' %}
                    <span class="pay-pill" {{ block.shopify_attributes }}>
                      {{ block.settings.title }}
                    </span>
                {% endcase %}
              {% endfor %}

              <span class="pay-secure">
                {% if section.settings.secure_icon != blank %}
                  {{ section.settings.secure_icon }}

                {% else %}
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <rect x="4" y="11" width="16" height="10" rx="2"></rect>
                    <path d="M8 11V7a4 4 0 0 1 8 0v4"></path>
                  </svg>
                {% endif %}

                {{ section.settings.secure_text }}
              </span>
            </div>

            <div class="drops" id="drops">
              <div class="drop">
                <button class="drop-q" aria-expanded="false">
                  What's in Your Kit
                  <span class="plus" aria-hidden="true"></span>
                </button>
                <div class="drop-a">
                  <div>
                    <div class="drop-inner">
                      <div class="kit-list">
                        <div class="kit-row">
                          <span class="kit-ico">
                            <svg
                              viewBox="0 0 32 32"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.6"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            >
                              <path
                                d="M5 14 C 7 6, 25 6, 27 14 L26 22 H6 Z"
                              ></path>
                              <path
                                d="M5 14 C 9 11, 23 11, 27 14"
                              ></path>
                            </svg>
                          </span>
                          <div>
                            <h5>Upper &amp; Lower Impression Trays</h5>
                            <p>For taking your impressions at home.</p>
                          </div>
                        </div>

                        <div class="kit-row">
                          <span class="kit-ico">
                            <svg
                              viewBox="0 0 32 32"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.6"
                            >
                              <circle cx="12" cy="16" r="6"></circle>
                              <circle cx="21" cy="16" r="6"></circle>
                            </svg>
                          </span>
                          <div>
                            <h5>Dental Putty (two batches)</h5>
                            <p>Extra putty included so you have room for error.</p>
                          </div>
                        </div>

                        <div class="kit-row">
                          <span class="kit-ico">
                            <svg
                              viewBox="0 0 32 32"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.6"
                            >
                              <rect
                                x="5"
                                y="8"
                                width="22"
                                height="16"
                                rx="2"
                              ></rect>
                              <rect x="8" y="11" width="3" height="10"></rect>
                              <rect
                                x="13"
                                y="11"
                                width="3"
                                height="10"
                              ></rect>
                              <rect
                                x="18"
                                y="11"
                                width="3"
                                height="10"
                              ></rect>
                              <rect
                                x="23"
                                y="11"
                                width="1.5"
                                height="10"
                              ></rect>
                            </svg>
                          </span>
                          <div>
                            <h5>Shade Matching Card</h5>
                            <p>A reference strip to capture your actual tooth color.</p>
                          </div>
                        </div>

                        <div class="kit-row">
                          <span class="kit-ico">
                            <svg
                              viewBox="0 0 32 32"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.6"
                              stroke-linejoin="round"
                            >
                              <path
                                d="M4 10 L16 4 L28 10 L28 24 L4 24 Z"
                              ></path>
                              <path d="M4 10 L16 16 L28 10"></path>
                            </svg>
                          </span>
                          <div>
                            <h5>Prepaid Return Mailer</h5>
                            <p>Drop it in any mailbox. No postage required.</p>
                          </div>
                        </div>

                        <div class="kit-row">
                          <span class="kit-ico">
                            <svg
                              viewBox="0 0 32 32"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.6"
                            >
                              <circle cx="16" cy="16" r="11"></circle>
                              <path
                                d="M13 11l8 5-8 5z"
                                fill="currentColor"
                                stroke="none"
                              ></path>
                            </svg>
                          </span>
                          <div>
                            <h5>Video Instructions</h5>
                            <p>A QR code to Dr. Turley's step-by-step walkthrough.</p>
                          </div>
                        </div>
                      </div>

                      <div class="drop-note">
                        If your first impressions do not capture enough detail, we send a second kit free.
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="drop">
                <button class="drop-q" aria-expanded="false">
                  Your Order Includes
                  <span class="plus" aria-hidden="true"></span>
                </button>
                <div class="drop-a">
                  <div>
                    <div class="drop-inner">
                      <div class="incl-grid">
                        <div class="incl-cell">
                          <span class="ic">
                            <svg
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.9"
                            >
                              <circle cx="12" cy="8" r="4"></circle>
                              <path d="M4 21c0-4 4-6 8-6s8 2 8 6"></path>
                            </svg>
                          </span>
                          <div>
                            <h5>Designed by Dr. Turley</h5>
                            <p>
                              Every case is produced against the 7-Point Smile Design Protocol he created as a cosmetic
                              dentist.
                            </p>
                          </div>
                        </div>

                        <div class="incl-cell">
                          <span class="ic">
                            <svg
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.9"
                              stroke-linejoin="round"
                            >
                              <path
                                d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"
                              ></path>
                            </svg>
                          </span>
                          <div>
                            <h5>30-Day Fit Remake (up to 2)</h5>
                            <p>
                              If the fit or look is not right, we remake it free within 30 days, with prepaid shipping
                              both ways.
                            </p>
                          </div>
                        </div>

                        <div class="incl-cell">
                          <span class="ic">
                            <svg
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.9"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            >
                              <rect
                                x="1"
                                y="7"
                                width="14"
                                height="10"
