                        <p>
                          {{ section.settings.guarantee_card_text }}
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="drop">
                <button class="drop-q" aria-expanded="false">
                  How to Start
                  <span class="plus" aria-hidden="true"></span>
                </button>
                <div class="drop-a">
                  <div>
                    <div class="drop-inner">
                      <div class="kit-list">
                        <div class="kit-row">
                          <span class="kit-ico kit-num">1</span>
                          <div>
                            <h5>Order your impression kit</h5>
                            <p>Pick your arches and check out. Your kit ships free within 48 hours.</p>
                          </div>
                        </div>

                        <div class="kit-row">
                          <span class="kit-ico kit-num">2</span>
                          <div>
                            <h5>Take impressions at home</h5>
                            <p>Follow Dr. Turley's video walkthrough, about five minutes, then mail them back free.</p>
