<section class="navy on-navy" id="protocol">
  <div class="wrap">
    <div class="sect-head">
      <div class="eyebrow on-navy">
        {{ section.settings.eyebrow }}
      </div>

      <h2 class="display" style="margin-top:14px">
        {{ section.settings.heading }}
      </h2>

      <p class="sub">
        {{ section.settings.description }}
      </p>
    </div>

    <div class="proto-grid">
      <div
        class="proto-tabs"
        id="protoTabs"
        role="tablist"
      ></div>

      <div
        class="proto-stage"
        id="protoStage"
        aria-live="polite"
      ></div>
    </div>

    <div
      class="proto-acc"
      id="protoAcc"
    ></div>

    <p class="proto-footer">
      {{ section.settings.footer_text }}
    </p>

    <div class="sect-cta-row">
      <a
        class="link-arrow"
        href="{{ section.settings.button_target }}"
      >
        {{ section.settings.button_text }}

        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  window.protocolData = [
    {% for block in section.blocks %}
      {
        n: {{ block.settings.number | json }},
        t: {{ block.settings.title | json }},
        p: {{ block.settings.description | json }},
        d: {{ block.settings.svg_code | json }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];

  const PROTOCOL = window.protocolData || [];

  (() => {

  const sectionId = 'protocol';

  const PROTOCOL = window[`protocolData`] || [];

  const protoTabs =
    document.getElementById(`protoTabs`);

  const protoStage =
    document.getElementById(`protoStage`);

  const protoAcc =
    document.getElementById(`protoAcc`);

  if (
    !protoTabs ||
    !protoStage ||
    !protoAcc ||
    !PROTOCOL.length
  ) return;

  let activeProto = 0;

  function renderProto() {

    const item = PROTOCOL[activeProto];

    protoStage.innerHTML = `
      <div class="proto-diagram proto-anim">
        ${item.d}
      </div>

      <div class="proto-detail proto-anim">
        <span class="pnum">
          Point ${item.n}
        </span>

        <h3>
          ${item.t}
        </h3>

        <p>
          ${item.p}
        </p>
      </div>
    `;
  }

  function setProto(index) {

    activeProto = index;

    protoTabs
      .querySelectorAll('.proto-tab')
      .forEach((tab, i) => {

        tab.classList.toggle(
          'active',
          i === index
        );

      });

    renderProto();
  }

  PROTOCOL.forEach((item, index) => {

    const tab = document.createElement('button');

    tab.className =
      `proto-tab ${
        index === 0 ? 'active' : ''
      }`;

    tab.setAttribute('role', 'tab');

    tab.innerHTML = `
      <span class="tn">
        ${item.n}
      </span>

      <span class="tt">
        ${item.t}
      </span>
    `;

    tab.addEventListener(
      'click',
      () => setProto(index)
    );

    tab.addEventListener(
      'mouseenter',
      () => setProto(index)
    );

    protoTabs.appendChild(tab);

    const acc =
      document.createElement('div');

    acc.className =
      `pa-item ${
        index === 0 ? 'open' : ''
      }`;

    acc.innerHTML = `
      <button class="pa-q">

        <span class="tn">
          ${item.n}
        </span>

        <span class="tt">
          ${item.t}
        </span>

        <svg
          class="pchev"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M6 9l6 6 6-6"/>
        </svg>

      </button>

      <div class="pa-a">
        <div>
          <p>
            ${item.p}
          </p>
        </div>
      </div>
    `;

    acc
      .querySelector('.pa-q')
      .addEventListener(
        'click',
        () => {

          const isOpen =
            acc.classList.contains('open');

          protoAcc
            .querySelectorAll('.pa-item')
            .forEach(item => {

              item.classList.remove(
                'open'
              );

            });

          if (!isOpen) {
            acc.classList.add('open');
          }

        }
      );

    protoAcc.appendChild(acc);

  });

  renderProto();

})();

</script>

