{% schema %}
{
  "name": "Protocol",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Protocol"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Seven decisions that make them look like your own teeth."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "textarea",
      "id": "footer_text",
      "label": "Footer Text"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "See how it works"
    },
    {
      "type": "text",
      "id": "button_target",
      "label": "Button Target",
      "default": "#how"
    }
  ],
  "blocks": [
    {
      "type": "protocol_item",
      "name": "Protocol Point",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "textarea",
          "id": "svg_code",
          "label": "SVG Code"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "7 Point Protocol",
      "blocks": [
        {
          "type": "protocol_item",
          "settings": {
            "title": "Smile Architecture",
            "description": "Your veneers are shaped to suit your face, not a template. Your lip line and facial proportions guide the design.",
            "svg_code": "<svg viewBox='0 0 100 100' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='M50 13C33 13 24 30 24 49c0 21 13 38 26 38s26-17 26-38C76 30 67 13 50 13Z'/><line x1='50' y1='16' x2='50' y2='84' stroke-width='1' stroke-dasharray='2 3' opacity='.32'/><line x1='27' y1='40' x2='73' y2='40' stroke-width='1' stroke-dasharray='2 3' opacity='.32'/><line x1='27' y1='60' x2='73' y2='60' stroke-width='1' stroke-dasharray='2 3' opacity='.32'/><path d='M37 63c5 7 21 7 26 0' stroke-width='1.8'/><path d='M41 65h18' stroke-width='1' opacity='.5'/></svg>"
          }
        },
        {
          "type": "protocol_item",
          "settings": {
            "title": "Bite Alignment",
            "description": "Your upper and lower teeth should meet naturally. Your bite is mapped so nothing feels off when you close.",
            "svg_code": "<svg viewBox='0 0 100 100' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='M16 36C32 22 68 22 84 36'/><path d='M24 37v9M34 35v12M45 34v13M55 34v13M66 35v12M76 37v9' stroke-width='1.1'/><path d='M16 64C32 78 68 78 84 64'/><path d='M24 63v-9M34 65v-12M45 66v-13M55 66v-13M66 65v-12M76 63v-9' stroke-width='1.1'/><line x1='14' y1='50' x2='86' y2='50' stroke-width='1' stroke-dasharray='3 3' opacity='.4'/></svg>"
          }
        },
        {
          "type": "protocol_item",
          "settings": {
            "title": "Tooth-by-Tooth Proportions",
            "description": "Each tooth is sized individually, no uniform chiclet look. The side teeth sit slightly smaller than the front ones, the way real teeth do.",
            "svg_code": ""
          }
        },
        {
          "type": "protocol_item",
          "settings": {
            "title": "Gumline Precision",
            "description": "The edge where veneer meets gum is where cheap snap-ons give themselves away. Yours is contoured to your own gumline so it doesn't look applied.",
            "svg_code": ""
          }
        },
        {
          "type": "protocol_item",
          "settings": {
            "title": "Natural Translucency",
            "description": "Real teeth aren't flat white. The biting edges are built with graduated translucency so they catch light the way enamel does.",
            "svg_code": ""
          }
        },
        {
          "type": "protocol_item",
          "settings": {
            "title": "Shade Matching",
            "description": "Your shade card is matched against a professional shade guide, calibrated to your natural teeth, not a generic Hollywood white.",
            "svg_code": ""
          }
        },
        {
          "type": "protocol_item",
          "settings": {
            "title": "Final Inspection",
            "description": "Every finished case is checked against the first six points. If anything is off, it's remade before it ships, at our cost, not yours.",
            "svg_code": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}
