<section id="candidate">
  <div class="wrap">
    <div class="sect-head">
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="display" style="margin-top: 14px">
        {{ section.settings.heading }}
      </h2>
      <p class="sub">
        {{ section.settings.description }}
      </p>
    </div>
    <div class="cand-grid">
      {% for block in section.blocks %}
        {% if block.type == 'candidate_card' %}
          <div
            class="ccard {{ block.settings.card_style }}"
            {{ block.shopify_attributes }}
          >
            <div class="ctitle">
              <span class="cdot"></span>
              {{ block.settings.title }}
            </div>

            <ul>
              {% for i in (1..4) %}
                {% assign key = 'item_' | append: i %}
                {% assign item = block.settings[key] %}

                {% if item != blank %}
                  <li>{{ item }}</li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    <div class="cand-cta">
      <div class="nudge">
        {{ section.settings.nudge_text }}
      </div>

      <a
        href="{{ section.settings.cta_target }}"
        class="cta"
        {% comment %} id="openQuiz" {% endcomment %}
        style="width:100%"
      >
        {{ section.settings.cta_text }}

        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
    </div>

    <p class="cand-disclaimer">
      {{ section.settings.disclaimer }}
    </p>
  </div>
</section>
{% schema %}
{
  "name": "Candidate",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Are You a Candidate?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Revive Veneers work for most people. They're not right for everyone."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "They're designed for people with healthy teeth who want a better-looking smile, not for people who need dental treatment. Here's an honest breakdown of who they're built for."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Take the 30-Second Smile Quiz"
    },
    {
      "type": "url",
      "id": "cta_target",
      "label": "CTA Target"
    },
    {
      "type": "richtext",
      "id": "nudge_text",
      "label": "Nudge Text",
      "default": "<p>Not sure? <strong>Take our free quiz.</strong> We'll tell you honestly.</p>"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "Revive Veneers are cosmetic appliances, not medical devices. They enhance the appearance of your smile but do not treat dental conditions. Dr. Brandon Turley, DDS, recommends consulting a licensed dentist for any underlying dental health concerns before ordering."
    }
  ],
  "blocks": [
    {
      "type": "candidate_card",
      "name": "Candidate Card",
      "settings": [
        {
          "type": "select",
          "id": "card_style",
          "label": "Card Style",
          "options": [
            {
              "value": "ideal",
              "label": "Ideal"
            },
            {
              "value": "good",
              "label": "Good"
            },
            {
              "value": "consult",
              "label": "Consult"
            },
            {
              "value": "not",
              "label": "Not Candidate"
            }
          ],
          "default": "ideal"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "item_1",
          "label": "Item 1"
        },
        {
          "type": "textarea",
          "id": "item_2",
          "label": "Item 2"
        },
        {
          "type": "textarea",
          "id": "item_3",
          "label": "Item 3"
        },
        {
          "type": "textarea",
          "id": "item_4",
          "label": "Item 4"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Candidate Section",
      "blocks": [
        {
          "type": "candidate_card",
          "settings": {
            "card_style": "ideal",
            "title": "Ideal candidates",
            "item_1": "Generally healthy teeth and gums",
            "item_2": "Want to improve the appearance of stained, slightly gapped, or worn teeth",
            "item_3": "All upper or all lower teeth present",
            "item_4": "No active gum disease or recent major dental work"
          }
        },
        {
          "type": "candidate_card",
          "settings": {
            "card_style": "good",
            "title": "Good candidates, extended timeline",
            "item_1": "Small to medium gaps in teeth",
            "item_2": "Minor bite issues (slight overbite or underbite)",
            "item_3": "Worn or short teeth from grinding",
            "item_4": "One or two missing teeth not at the end of the arch"
          }
        },
        {
          "type": "candidate_card",
          "settings": {
            "card_style": "consult",
            "title": "Consult before ordering",
            "item_1": "Active gum disease or significant gum recession",
            "item_2": "Severe crossbite or bite alignment issues",
            "item_3": "Recent major dental work within the last 3 months",
            "item_4": "Multiple missing teeth or teeth missing at the end of the arch"
          }
        },
        {
          "type": "candidate_card",
          "settings": {
            "card_style": "not",
            "title": "Not a candidate",
            "item_1": "No remaining teeth in the arch you want covered",
            "item_2": "Currently wearing full dentures",
            "item_3": "Active oral infection or untreated periodontal disease",
            "item_4": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}
