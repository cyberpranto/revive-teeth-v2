{% comment %}
  <div class="trust">
    <div class="wrap">
      <div class="trust-grid">
        <div class="tbadge">
          <span class="tb-ic">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
            >
              <circle cx="12" cy="8" r="4"></circle>
              <path d="M4 21c0-4 4-6 8-6s8 2 8 6"></path>
            </svg>
          </span>
          <div class="tb-t">Dentist-Designed</div>
          <div class="tb-s">Every case by Dr. Turley, DDS</div>
        </div>
        <div class="tbadge">
          <span class="tb-ic">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linejoin="round"
            >
              <path
                d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"
              ></path>
            </svg>
          </span>
          <div class="tb-t">30-Day Money-Back</div>
          <div class="tb-s">Full refund if it isn't right</div>
        </div>
        <div class="tbadge">
          <span class="tb-ic">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="9"></circle>
              <path d="M12 7v5l3 2"></path>
            </svg>
          </span>
          <div class="tb-t">3–5 Year Lifespan</div>
          <div class="tb-s">Durable dental-grade resin</div>
        </div>
        <div class="tbadge">
          <span class="tb-ic">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linejoin="round"
            >
              <path
                d="M12 3 C 12 9, 18 12, 18 17 a6 6 0 0 1 -12 0 C 6 12, 12 9, 12 3 Z"
              ></path>
            </svg>
          </span>
          <div class="tb-t">BPA-Free Resin</div>
          <div class="tb-s">Safe cosmetic-grade material</div>
        </div>
        <div class="tbadge">
          <span class="tb-ic">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M3 12h13l-4-4M16 12l-4 4"></path>
              <path d="M21 6v12"></path>
            </svg>
          </span>
          <div class="tb-t">Ships Free Both Ways</div>
          <div class="tb-s">Kit, return &amp; veneers covered</div>
        </div>
        <div class="tbadge">
          <span class="tb-ic">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M3 12a9 9 0 0 1 15.5-6.3L21 8"></path>
              <path d="M21 4v4h-4"></path>
              <path d="M21 12a9 9 0 0 1-15.5 6.3L3 16"></path>
              <path d="M3 20v-4h4"></path>
            </svg>
          </span>
          <div class="tb-t">Free Remakes</div>
          <div class="tb-s">Until the fit is right</div>
        </div>
      </div>
    </div>
  </div>
{% endcomment %}

<div class="trust">
  <div class="wrap">
    <div class="trust-grid">
      {% for block in section.blocks %}
        <div class="tbadge" {{ block.shopify_attributes }}>
          {% if block.settings.icon_svg != blank %}
            <span class="tb-ic">
              {{ block.settings.icon_svg }}
            </span>
          {% endif %}

          <div class="tb-t">
            {{ block.settings.title }}
          </div>

          <div class="tb-s">
            {{ block.settings.subtitle }}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

