{% if section.settings.image != blank %}
  <div
    class="full-width-image lifestyle-band"
    style="margin-top:{{ section.settings.margin_top }}px; margin-bottom:{{ section.settings.margin_bottom }}px;"
  >
    <img
      src="{{ section.settings.image | image_url: width: 2000 }}"
      alt="{{ section.settings.image.alt }}"
      width="100%"
      height="auto"
      loading="{{ section.settings.loading }}"
      style="display:block; width:100%; height:auto;"
    >
  </div>
{% endif %}

{% schema %}
{
  "name": "Full Width Image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 0
    },
    {
      "type": "select",
      "id": "loading",
      "label": "Image loading",
      "options": [
        { "value": "lazy", "label": "Lazy (recommended)" },
        { "value": "eager", "label": "Eager (above the fold)" }
      ],
      "default": "lazy"
    }
  ],
  "presets": [
    {
      "name": "Full Width Image"
    }
  ]
}
{% endschema %}
