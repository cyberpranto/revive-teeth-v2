<!-- ============== FOOTER ============== -->
<footer id="footer">
  <div class="wrap">
    <div class="foot-grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'brand' %}
            <div class="foot foot-brand" {{ block.shopify_attributes }}>
              <div class="brand">
                {% if block.settings.logo %}
                  <img
                    src="{{ block.settings.logo | image_url: width: 500 }}"
                    alt="{{ shop.name }}"
                    loading="lazy"
                    width="100"
                    height="100"
                  >
                {% else %}
                  <img
                    src="{{ 'footer-logo.jfif' | asset_url }}"
                    alt="{{ shop.name }}"
                    loading="lazy"
                    width="100"
                    height="100"
                  >
                {% endif %}
              </div>

              <p class="tag">
                {{ block.settings.tagline }}
              </p>
              <p class="tag">
                {{ block.settings.address }}
              </p>
            </div>

          {% when 'menu' %}
            <div class="foot" {{ block.shopify_attributes }}>
              <h5>
                {{ block.settings.heading }}
              </h5>

              <ul>
                {% for link in block.settings.menu.links %}
                  <li>
                    <a href="{{ link.url }}">
                      {{ link.title }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            </div>

          {% when 'text' %}
            <div class="foot" {{ block.shopify_attributes }}>
              <h5>
                {{ block.settings.heading }}
              </h5>

              <div class="foot-tagline-small">
                {{ block.settings.content }}
              </div>
            </div>

          {% when 'newsletter' %}
            <div class="foot" {{ block.shopify_attributes }}>
              <h5>
                {{ block.settings.heading }}
              </h5>

              <form
                id="newsletter-form"
                class="sub-input"
                data-list-id="{{ section.settings.klaviyo_list_id }}"
              >
                <input
                  id="newsletter-email"
                  type="email"
                  placeholder="you@example.com"
                  required
                >

                <button
                  id="newsletter-submit"
                  type="submit"
                >
                  Subscribe
                </button>
              </form>

              <div id="newsletter-message"></div>

              <div class="foot-tagline-small">
                {{ block.settings.subtext }}
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>

    <div class="foot-bottom">
      <div>
        {{ section.settings.copyright }}
      </div>

      <div class="legal">
        {% for link in section.settings.legal_menu.links %}
          <a href="{{ link.url }}">
            {{ link.title }}
          </a>

          {% unless forloop.last %}
            <span style="opacity:.4">·</span>
          {% endunless %}
        {% endfor %}
      </div>
    </div>

    <p class="foot-disclaimer">
      {{ section.settings.disclaimer }}
    </p>
  </div>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('newsletter-form');

    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = document.getElementById('newsletter-email').value;

      const button = document.getElementById('newsletter-submit');

      const message = document.getElementById('newsletter-message');

      const listId = form.dataset.listId;

      button.disabled = true;

      const originalText = button.textContent;

      button.textContent = 'Subscribing...';

      try {
        await fetch('https://manage.kmail-lists.com/ajax/subscriptions/subscribe', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
          },
          body: new URLSearchParams({
            g: listId,
            email: email,
          }),
        });

        message.textContent = 'Thanks for subscribing!';

        form.reset();

        button.textContent = 'Subscribed';
      } catch (error) {
        console.error(error);

        message.textContent = 'Something went wrong.';

        button.textContent = originalText;
      }

      button.disabled = false;
    });
  });
</script>

{% schema %}
{
  "name": "Revive Footer",
  "settings": [
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright Text",
      "default": "© 2026 Revive Teeth. All rights reserved."
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Legal Menu"
    },
    {
      "type": "text",
      "id": "klaviyo_list_id",
      "label": "Klaviyo List ID"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "default": "Cosmetic dentistry without the dental chair."
        },
        {
          "type": "richtext",
          "id": "address",
          "label": "Address",
          "default": "<p>Cosmetic dentistry without the dental chair.</p>"
        }
      ]
    },
    {
      "type": "menu",
      "name": "Menu Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Get smile design tips from Dr. Turley"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "No spam. Unsubscribe anytime."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Revive Footer",
      "blocks": [
        {
          "type": "brand"
        },
        {
          "type": "menu",
          "settings": {
            "heading": "Customer Support"
          }
        },
        {
          "type": "text",
          "settings": {
            "heading": "Payment"
          }
        },
        {
          "type": "newsletter"
        }
      ]
    }
  ]
}
{% endschema %}
