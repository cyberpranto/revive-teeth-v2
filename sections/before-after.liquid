<section class="warm" id="before-after">
  <div class="wrap">
    <div class="sect-head center">
      <div class="eyebrow">
        {{ section.settings.eyebrow }}
      </div>

      <h2 class="display" style="margin-top:14px">
        {{ section.settings.heading }}
      </h2>

      <p class="sub">
        {{ section.settings.subheading }}
      </p>
    </div>
    <div class="ba-grid">
      {% for block in section.blocks %}
        <div class="ba-card" {{ block.shopify_attributes }}>
          <div class="ba-pair">
            <span class="ba-tag b">
              {{ section.settings.before_label }}
            </span>

            <span class="ba-tag a">
              {{ section.settings.after_label }}
            </span>

            <!-- BEFORE -->

            <div class="image-slot before">
              {% if block.settings.before_image != blank %}
                <img
                  src="{{ block.settings.before_image | image_url: width: 1200 }}"
                  alt="{{ section.settings.before_image.alt }}"
                  loading="lazy"
                  width="1200"
                  height="1200"
                >

              {% else %}
                <div class="empty">
                  {{ section.settings.placeholder_icon }}

                  <div class="cap">
                    {{ section.settings.before_label }}
                  </div>
                </div>
              {% endif %}
            </div>

            <!-- AFTER -->

            <div class="image-slot after">
              {% if block.settings.after_image != blank %}
                <img
                  src="{{ block.settings.after_image | image_url: width: 1200 }}"
                   alt="{{ section.settings.after_image.alt }}"
                  loading="lazy"
                  width="1200"
                  height="1200"
                >

              {% else %}
                <div class="empty">
                  {{ section.settings.placeholder_icon }}

                  <div class="cap">
                    {{ section.settings.after_label }}
                  </div>
                </div>
              {% endif %}

              <div class="ring"></div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
    <p class="ba-honest">
      {{ section.settings.bottom_text }}
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Before After",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Before & After"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See the difference, side by side."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real cases, photographed under the same lighting, no filters, no retouching."
    },
    {
      "type": "liquid",
      "id": "placeholder_icon",
      "label": "Placeholder SVG"
    },
    {
      "type": "textarea",
      "id": "bottom_text",
      "label": "Bottom Text",
      "default": "Until we have real customer photos to show, we'd rather leave these panels honest and empty than fake a result."
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Before Label",
      "default": "Before"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "After Label",
      "default": "After"
    }
  ],
  "blocks": [
    {
      "type": "before_after",
      "name": "Before / After",
      "settings": [
        {
          "type": "image_picker",
          "id": "before_image",
          "label": "Before Image"
        },
        {
          "type": "image_picker",
          "id": "after_image",
          "label": "After Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Before After",
      "blocks": [
        {
          "type": "before_after"
        },
        {
          "type": "before_after"
        },
        {
          "type": "before_after"
        }
      ]
    }
  ]
}
{% endschema %}

