            class="arch-icon"
            viewBox="0 0 60 40"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 16 C 8 0, 52 0, 56 16"></path>
            <path d="M4 24 C 8 40, 52 40, 56 24"></path>
          </svg>
          <div>
            <div class="opt-name">Both Arches</div>
            <div class="opt-price">$1,994</div>
            <div class="save">Save $600 vs. buying separately</div>
          </div>
        </button>
      </div>
      <div class="price-block">
        <div class="price-top">
          <div class="price-now" id="priceNow">{{ current_variant.price | money_without_trailing_zeros }}</div>
        </div>
        <div class="price-pay">
