{% assign product = section.settings.product %}

{% if product == blank %}
  <p>Please select a product.</p>
  {% break %}
{% endif %}

{% assign current_variant = product.selected_or_first_available_variant %}

<section class="hero">
  <div class="wrap hero-grid">
    <!-- Gallery -->
    <div class="gallery">
      <div class="gallery-main" id="galMain">
        <img
          id="galImg"
          src="{{ product.featured_image | image_url: width: 1200 }}"
          alt="{{ product.featured_image.alt }}"
          height="100"
          width="100"
        >
      </div>
      <div class="thumbs" id="thumbs">
        {% for image in product.images %}
          <button
            class="thumb {% if forloop.first %}active{% endif %}"
            data-image="{{ image | image_url: width: 1200 }}"
            data-alt="{{ image.alt | escape }}"
            aria-label="{{ image.alt | escape }}"
          >
            <img
              src="{{ image | image_url: width: 200 }}"
              alt="{{ image.alt | escape }}"
              width="200"
              height="200"
            >
          </button>
        {% endfor %}
      </div>
    </div>
    <!-- Buybox -->
    <div class="buybox">
      <div class="eyebrow-sm">{{ section.settings.eyebrow }}</div>
      <h1 class="display">{{ section.settings.heading }}</h1>
      <p class="lead">
        {{ section.settings.description }}
      </p>
      <div class="hero-badges">
        {% for block in section.blocks %}
          {% if block.type == 'hero_badge' %}
            <span class="hbadge" {{ block.shopify_attributes }}>
              {% if block.settings.icon != blank %}
                {{ block.settings.icon }}
              {% endif %}

              {{ block.settings.text }}
            </span>
          {% endif %}
        {% endfor %}
      </div>
      <hr>
      <div class="config-label">Configuration <span class="req">· Choose one</span></div>
      <div
        class="config"
        id="config"
        role="radiogroup"
        aria-label="Configuration"
      >
        {% for variant in product.variants %}
          <button
            class="opt {% if forloop.first %}selected{% endif %}"
            role="radio"
            aria-checked="{% if forloop.first %}true{% else %}false{% endif %}"
            data-variant-id="{{ variant.id }}"
            data-price="{{ variant.price }}"
          >
            {% if variant.title contains 'Upper' %}
              {{ section.settings.upper_icon }}

            {% elsif variant.title contains 'Lower' %}
              {{ section.settings.lower_icon }}

            {% else %}
              <span class="badge">
                {{ section.settings.popular_badge }}
              </span>

              {{ section.settings.both_icon }}
            {% endif %}

            <div>
              <div class="opt-name">
                {{ variant.title }}
              </div>

              <div class="opt-price">
                {{ variant.price | money_without_trailing_zeros }}
              </div>

              {% if variant.title contains 'Both' %}
                <div class="save">
                  {{ section.settings.bundle_save_text }}
                </div>
              {% endif %}
            </div>
          </button>
        {% endfor %}
      </div>
      <div class="config-label">Configuration <span class="req">· Choose one</span></div>
      <div
        class="config"
        id="config"
        role="radiogroup"
        aria-label="Configuration"
      >
        <button
          class="opt"
          role="radio"
          aria-checked="false"
          data-key="upper"
          data-price="1297"
        >
          <svg
            class="arch-icon"
            viewBox="0 0 60 32"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 22 C 8 6, 52 6, 56 22"></path>
            <path
              d="M12 12 L12 19 M20 9 L20 18 M30 7.5 L30 17.5 M40 9 L40 18 M48 12 L48 19"
              stroke-width="1.6"
            ></path>
          </svg>
          <div>
            <div class="opt-name">Upper Arch</div>
            <div class="opt-price">$1,297</div>
          </div>
        </button>
        <button
          class="opt"
          role="radio"
          aria-checked="false"
          data-key="lower"
          data-price="1297"
        >
          <svg
            class="arch-icon"
            viewBox="0 0 60 32"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 10 C 8 26, 52 26, 56 10"></path>
            <path
              d="M12 20 L12 13 M20 23 L20 14 M30 24.5 L30 14.5 M40 23 L40 14 M48 20 L48 13"
              stroke-width="1.6"
            ></path>
          </svg>
          <div>
            <div class="opt-name">Lower Arch</div>
            <div class="opt-price">$1,297</div>
          </div>
        </button>
        <button
          class="opt selected"
          role="radio"
          aria-checked="true"
          data-key="both"
          data-price="1994"
        >
          <span class="badge">Most Popular</span>
