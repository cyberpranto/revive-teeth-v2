<section id="how">
    <div class="wrap">
      <div class="sect-head center">
        <div class="eyebrow">How It Works</div>
        <h2 class="display" style="margin-top: 14px">
          A better smile, mailed to your door.
        </h2>
        <p class="sub">
          No dental chair, no drilling, no multiple visits. Three simple
          steps, mostly from your couch — every case is designed to Dr.
          Turley's 7-point protocol in between.
        </p>
      </div>
      <div class="hiw-grid">
        <div class="hiw-step">
          <div class="hiw-ico">
            <span class="hiw-num">1</span>
            <svg
              viewBox="0 0 32 32"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linejoin="round"
            >
              <path d="M4 11 L16 5 L28 11 L28 25 L4 25 Z"></path>
              <path d="M4 11 L16 17 L28 11"></path>
              <path d="M16 17 L16 27"></path>
            </svg>
          </div>
          <div>
            <h3>Order your impression kit</h3>
            <p>
              Pick your arches and check out. Your kit ships free within 48
              hours, with everything you need and a backup batch of putty.
            </p>
            <span class="hiw-time"
              ><svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h13l-4-4M18 12l-4 4"></path></svg
              >Ships in 48 hours</span
            >
          </div>
        </div>
        <div class="hiw-step">
          <div class="hiw-ico">
            <span class="hiw-num">2</span>
            <svg
              viewBox="0 0 32 32"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 13 C 7 6, 25 6, 27 13 L25 22 H7 Z"></path>
              <path d="M5 13 C 9 10, 23 10, 27 13"></path>
            </svg>
          </div>
          <div>
            <h3>Take impressions at home</h3>
            <p>
              Follow Dr. Turley's video walkthrough, about five minutes. Drop
              the prepaid mailer in any USPS box to send them back, free.
            </p>
            <span class="hiw-time"
              ><svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M12 7v5l3 2"></path></svg
              >About 5 minutes</span
            >
          </div>
        </div>
        <div class="hiw-step">
          <div class="hiw-ico">
            <span class="hiw-num">3</span>
            <svg
              viewBox="0 0 32 32"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M6 13 C 10 24, 22 24, 26 13"></path>
              <path d="M6 13 C 9 11, 23 11, 26 13"></path>
              <path
                d="M11 12.5 L11 15 M16 12.5 L16 15.5 M21 12.5 L21 15"
              ></path>
            </svg>
          </div>
          <div>
            <h3>Receive your custom smile</h3>
            <p>
              Your veneers are made to your impressions and designed against
              Dr. Turley's 7-point protocol. They arrive ready to snap on and
              wear.
            </p>
            <span class="hiw-time"
              ><svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="4" y="6" width="16" height="14" rx="2"></rect>
                <path d="M4 10h16M9 3v4M15 3v4"></path></svg
                >2-3 weeks</span
            >
          </div>
        </div>
      </div>
      <div class="sect-cta-row">
        <button class="btn-primary scroll-buy">
          Start your smile
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </button>
      </div>
    </div>
  </section>