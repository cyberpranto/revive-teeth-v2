<!-- ============== NAV ============== -->

<style>
    #shopify-section-{{section.id}} {
    position: sticky;
    top: 0;
    z-index: 50;
  }

  #shopify-section-{{section.id}} header#nav {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: saturate(140%) blur(8px);
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
    border-bottom: 1px solid transparent;
    overflow: visible;
    transform: none;
  }

  #shopify-section-{{section.id}} header#nav.scrolled {
    border-bottom-color: var(--line);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.02);
  }
</style>

<header class="nav" id="nav">
  <div class="wrap nav-inner">
    <a
      href="{{ shop.url }}"
      class="brand"
      aria-label="{{ shop.name }}"
    >
      {% if section.settings.logo %}
        <img
          src="{{ section.settings.logo | image_url: width: 400 }}"
          alt="{{ shop.name }}"
          width="200"
          height="100"
          loading="eager"
        >
      {% else %}
        <img
          src="{{ 'footer-logo.jfif' | asset_url }}"
          alt="{{ shop.name }}"
          width="200"
          height="100"
          loading="eager"
        >
      {% endif %}
    </a>

    <nav
      class="navlinks"
      aria-label="Primary"
    >
      {% for block in section.blocks %}
        {% if block.type == 'menu_item' %}
          <a
            href="{{ block.settings.link }}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.label }}
          </a>
        {% endif %}
      {% endfor %}
    </nav>

    <div class="nav-right">
      <a
        href="/checkout"
        class="cart-btn"
        aria-label="Cart"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
        >
          <path d="M6 6h15l-1.5 9h-12z"></path>
          <circle cx="9" cy="20" r="1.5"></circle>
          <circle cx="18" cy="20" r="1.5"></circle>
          <path d="M6 6L4 2H2"></path>
        </svg>

        {{ section.settings.cart_text }}

        <span
          class="count"
          id="cartCount"
        >
          {{ cart.item_count }}
        </span>
      </a>
    </div>
  </div>
</header>

<a id="top"></a>

{% schema %}
{
  "name": "Navigation",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "url",
      "id": "logo_link",
      "label": "Logo Link"
    },
    {
      "type": "text",
      "id": "cart_text",
      "label": "Cart Text",
      "default": "Cart"
    }
  ],
  "blocks": [
    {
      "type": "menu_item",
      "name": "Menu Item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Menu Label"
        },
        {
          "type": "text",
          "id": "link",
          "label": "Anchor / URL",
          "default": "#"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Navigation",
      "blocks": [
        {
          "type": "menu_item",
          "settings": {
            "label": "Meet the Designer",
            "link": "#designer"
          }
        },
        {
          "type": "menu_item",
          "settings": {
            "label": "How It Works",
            "link": "#how"
          }
        },
        {
          "type": "menu_item",
          "settings": {
            "label": "Results",
            "link": "#results"
          }
        },
        {
          "type": "menu_item",
          "settings": {
            "label": "Before & After",
            "link": "#before-after"
          }
        },
        {
          "type": "menu_item",
          "settings": {
            "label": "The Protocol",
            "link": "#protocol"
          }
        },
        {
          "type": "menu_item",
          "settings": {
            "label": "Am I a Candidate?",
            "link": "#candidate"
          }
        },
        {
          "type": "menu_item",
          "settings": {
            "label": "FAQ",
            "link": "#faq"
          }
        }
      ]
    }
  ],
  "max_blocks": 10
}
{% endschema %}
