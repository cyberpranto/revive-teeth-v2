<!-- ============== NAV ============== -->
{% comment %}
  <style>
    #shopify-section-{{section.id}} {
    position: sticky;
    top: 0;
    z-index: 50;
  }

  #shopify-section-{{section.id}} header#nav {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: saturate(140%) blur(8px);
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
    border-bottom: 1px solid transparent;
    overflow: visible;
    transform: none;
  }

  #shopify-section-{{section.id}} header#nav.scrolled {
    border-bottom-color: var(--line);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.02);
  }
  </style>
{% endcomment %}
<header class="nav" id="nav">
  <div class="wrap nav-inner">
    <a href="#top" class="brand" aria-label="Revive Teeth">
      <img src="{{ "footer-logo.jfif" |  asset_url}}" alt="Revive Teeth" height="100" width="100">
    </a>
    <nav class="navlinks" aria-label="Primary">
      <a href="#designer">Meet the Designer</a>
      <a href="#how">How It Works</a> <a href="#results">Results</a>
      <a href="#before-after">Before &amp; After</a>
      <a href="#protocol">The Protocol</a>
      <a href="#candidate">Am I a Candidate?</a> <a href="#faq">FAQ</a>
    </nav>
    <div class="nav-right">
      <button class="cart-btn" aria-label="Cart">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
        >
          <path d="M6 6h15l-1.5 9h-12z"></path>
          <circle cx="9" cy="20" r="1.5"></circle>
          <circle cx="18" cy="20" r="1.5"></circle>
          <path d="M6 6L4 2H2"></path>
        </svg>
        Cart <span class="count" id="cartCount">0</span>
      </button>
    </div>
  </div>
</header>
<a id="top"></a>

{% schema %}
{
  "name": "Navigation",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "url",
      "id": "logo_link",
      "label": "Logo Link"
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Logo Alt Text",
      "default": "Revive Teeth"
    },
    {
      "type": "text",
      "id": "cart_text",
      "label": "Cart Text",
      "default": "Cart"
    }
  ],
  "blocks": [
    {
      "type": "menu_item",
      "name": "Menu Item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Menu Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Menu Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Navigation",
      "blocks": [
        {
          "type": "menu_item",
          "settings": {
            "label": "How It Works",
            "link": "#how"
          }
        },
        {
          "type": "menu_item",
          "settings": {
            "label": "The Protocol",
            "link": "#protocol"
          }
        },
        {
          "type": "menu_item",
          "settings": {
            "label": "Reviews",
            "link": "#reviews"
          }
        },
        {
          "type": "menu_item",
          "settings": {
            "label": "Am I a Candidate?",
            "link": "#candidate"
          }
        },
        {
          "type": "menu_item",
          "settings": {
            "label": "FAQ",
            "link": "#faq"
          }
        }
      ]
    }
  ],
  "max_blocks": 10
}
{% endschema %}
