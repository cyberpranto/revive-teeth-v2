<section class="bridge">
  <div class="wrap">
    <span class="bridge-text">
      {{ section.settings.content }}
    </span>

    <a
      href="{{ section.settings.button_link }}"
      class="link-arrow bridge-cta"
    >
      {{ section.settings.button_text }}

      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M5 12h14M13 6l6 6-6 6"></path>
      </svg>
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Emotional Bridge",
  "settings": [
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>You stopped smiling in photos years ago. You laugh with a hand over your mouth. You've looked into fixing it — $15,000 and a dental chair felt out of reach. <em>This is the other way.</em></p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "See how it works"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Emotional Bridge",
      "settings": {
        "content": "<p>You stopped smiling in photos years ago. You laugh with a hand over your mouth. You've looked into fixing it — $15,000 and a dental chair felt out of reach. <em>This is the other way.</em></p>",
        "button_text": "See how it works",
        "button_link": "#how"
      }
    }
  ]
}
{% endschema %}
