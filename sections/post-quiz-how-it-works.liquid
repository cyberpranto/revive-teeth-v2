          }
        },
        {
          "type": "step",
          "settings": {
            "fallback_image": "hiw-step-2.jfif",
            "step": "Step 02",
            "title": "Take impressions at home",
            "description": "Follow Dr. Turley's video walkthrough. It takes about five minutes. Drop the prepaid mailer in the mail to send them back free.",
            "timing": "About 5 minutes",
            "icon_svg": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"9\"></circle><path d=\"M12 7v5l3 2\"></path></svg>"
          }
        },
        {
          "type": "step",
          "settings": {
            "fallback_image": "hiw-step-3.jfif",
            "step": "Step 03",
            "title": "Receive your custom smile",
            "description": "Your veneers are made to your impressions and built to Dr. Turley's protocol. They arrive ready to wear.",
