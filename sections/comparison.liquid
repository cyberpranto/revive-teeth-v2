      "type": "spectrum_card",
      "settings": {
        "title": "Generic snap-ons online",
        "price": "$200–$400",
        "description": "One-size mold, no dentist involved, the look most people quietly stop wearing."
      }
    }
  ]
}
  ]
}
{% endschema %}
