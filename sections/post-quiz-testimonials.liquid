      "id": "check_icon",
      "label": "Verified Icon SVG (Optional)",
      "default": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12l5 5 9-11\"></path></svg>"
    }
  ],
  "blocks": [
