  ],
  "max_blocks": 4,

  "presets": [
    {
      "name": "Post Quiz Testimonials",
      "category": "Post Quiz",
      "blocks": [
        {
          "type": "story"
        },
        {
          "type": "story"
        },
        {
          "type": "story"
        },
        {
          "type": "story"
        }
      ]
    }
  ]
}
{% endschema %}
