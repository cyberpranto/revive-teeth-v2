          "label": "Customer Name",
          "default": "Joshua"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "I'm in sales, so confidence is everything. Now I can feel myself smiling without even trying."
        },
        {
          "type": "text",
          "id": "badge",
