<style>
  .founder-video {
    position: relative;
    border-radius: var(--r-card);
    overflow: hidden;
    aspect-ratio: 16/9;
    background: linear-gradient(160deg, #263c70, #16264c);
    box-shadow: var(--shadow-hover);
  }
  .founder-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .fv-overlay {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    cursor: pointer;
    background: linear-gradient(180deg, rgba(13, 27, 42, 0.15), rgba(13, 27, 42, 0.5));
    transition: opacity 0.3s ease;
  }
  .fv-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }
  .fv-play {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
    display: grid;
    place-items: center;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.45);
    transition: transform 0.15s;
  }
  .fv-overlay:hover .fv-play {
    transform: scale(1.07);
  }
  .fv-play svg {
    width: 27px;
    height: 27px;
    color: #0d1b2a;
    margin-left: 4px;
  }
  .fv-cap {
    position: relative;
    z-index: 1;
    margin-top: 18px;
    text-align: center;
    font-size: 13px;
    color: #8b97b8;
    letter-spacing: 0.01em;
  }
</style>

<section class="sec-cream" id="designer">
  <div class="wrap">
    <div class="founder-grid">
      <div class="founder-text reveal">
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <p class="founder-quote">
          {{ section.settings.quote }}
        </p>

        <div class="founder-body prose">
          {{ section.settings.story }}
        </div>

        <p class="founder-shield">
          {{ section.settings.shield }}
        </p>

        <div class="founder-body prose">
          {{ section.settings.bottom_story }}
        </div>

        <div class="sig-block">
          {% if section.settings.signature_image != blank %}
            <img
              src="{{ section.settings.signature_image | image_url: width: 250 }}"
              alt="{{ section.settings.founder_name }}"
              class="sig-img"
              width="120"
              height="120"
            >
          {% else %}
            <img
              src="{{ 'founder-image.jfif' | asset_url }}"
              alt="{{ section.settings.founder_name }}"
              class="sig-img"
              width="120"
              height="120"
            >
          {% endif %}
          <div class="sig-name">{{ section.settings.founder_name }}</div>

          <div class="sig-sub">{{ section.settings.founder_designation }}</div>
        </div>
      </div>

      <div class="founder-media reveal" data-delay="100">
        <div class="founder-video">
          {% assign video = section.settings.video %}
          {% assign poster = section.settings.video_poster %}

          {% if video != blank %}
            <video
              id="founderVideo-{{ section.id }}"
              preload="metadata"
              playsinline
              {% if poster != blank %}
                poster="{{ poster | image_url: width: 1200 }}"
              {% elsif video.preview_image %}
                poster="{{ video.preview_image | image_url: width: 1200 }}"
              {% else %}
                poster="{{ 'founder-image.jfif' | asset_url }}"
              {% endif %}
            >
              <source
                src="{{ video.sources.first.url }}"
                type="{{ video.sources.first.mime_type }}"
              >
            </video>
          {% endif %}

          <div class="fv-overlay" id="fvOverlay-{{ section.id }}">
            <span class="fv-play" aria-label="Play founder video">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M6 4l14 8-14 8z"></path>
              </svg>
            </span>
          </div>
        </div>
        <div class="founder-creds">
          {% for block in section.blocks %}
            {% if block.type == 'credential' %}
              <div class="cred" {{ block.shopify_attributes }}>
                {% if block.settings.icon_svg != blank %}
                  {{ block.settings.icon_svg }}
                {% endif %}

                <span>
                  {{ block.settings.text }}
                </span>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
<script>
  /* ============== FOUNDER VIDEO ============== */
  (function () {
    const v = document.getElementById('founderVideo-{{ section.id }}');
    const overlay = document.getElementById('fvOverlay-{{ section.id }}');
    if (!v || !overlay) return;
    overlay.addEventListener('click', () => {
      const playPromise = v.play();

      if (playPromise) {
        playPromise.catch(() => {});
      }
    });
    v.addEventListener('click', () => {
      if (v.paused) {
        v.play();
      } else {
        v.pause();
      }
    });
    v.addEventListener('play', () => overlay.classList.add('hidden'));
    v.addEventListener('pause', () => overlay.classList.remove('hidden'));
    v.addEventListener('ended', () => {
      overlay.classList.remove('hidden');
      v.currentTime = 0;
    });
  })();
</script>
{% schema %}
{
  "name": "Post Quiz Founder Story",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "What I kept watching."
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "I have sat across from patients who cover their mouths when they laugh. It is the hardest thing to watch as a dentist."
    },
    {
      "type": "richtext",
      "id": "story",
      "label": "Main Story",
      "default": "<p>In my practice, I hear the same story every week. A patient comes in. They hate their smile. They have stopped being in photos with their kids. They want it fixed, but the clinical reality is brutal: traditional porcelain veneers mean hours in my chair, permanently drilling down healthy enamel, and a bill between ten and twenty thousand dollars.</p><p>For most hardworking people, that is not an option.</p><p>So they go online and buy a cheap plastic snap-on for a couple hundred dollars. A few weeks later, they are sitting in my chair again, showing me what arrived. It is always the same. The appliance is stamped from a single mold. The gingival margin, the gumline, is a straight, thick plastic ridge. The teeth look like identical white piano keys. They put it in, realize everyone can immediately tell it is fake, and throw it in a drawer.</p><p>They paid good money to feel worse than when they started. And the companies selling these things keep selling them anyway, because the customer is too embarrassed to complain publicly.</p><p>I got tired of seeing it. I know exactly what makes a tooth look real. It is not magic. It is proportion, translucency, and how the edge meets the gum. I knew those clinical standards could be engineered into a removable appliance if someone actually did the work. So I did.</p><p>Every Revive case is produced against the 7-Point Smile Design Protocol I built. If a case does not pass my standard, it does not ship.</p>"
    },
    {
      "type": "textarea",
      "id": "shield",
      "label": "Shield Text",
      "default": "Let me be clear about one thing. I am a cosmetic dentist, but I am not your dentist, and Revive is not dental treatment. I designed a product."
    },
    {
      "type": "richtext",
      "id": "bottom_story",
      "label": "Bottom Story",
      "default": "<p>I designed the standard behind it too, so a more natural-looking appliance could be made for people who had almost given up on their smile.</p>"
    },
    {
      "type": "image_picker",
      "id": "signature_image",
      "label": "Signature Image"
    },
    {
      "type": "text",
      "id": "founder_name",
      "label": "Founder Name",
      "default": "Dr. Brandon Turley, DDS"
    },
    {
      "type": "text",
      "id": "founder_designation",
      "label": "Founder Designation",
      "default": "Doctor of Dental Surgery · Founder, Revive Teeth"
    },
    {
      "type": "text",
      "id": "video_label",
      "label": "Video Label",
      "default": "[ Video · Dr. Turley ]"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Founder Video"
    },
    {
      "type": "image_picker",
      "id": "video_poster",
      "label": "Video Poster"
    }
  ],
  "blocks": [
    {
      "type": "credential",
      "name": "Credential",
      "settings": [
        {
          "type": "textarea",
          "id": "icon_svg",
          "label": "SVG"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Post Quiz Founder Story",
      "blocks": [
        {
          "type": "credential",
          "settings": {
            "text": "12+ Years Experience"
          }
        },
        {
          "type": "credential",
          "settings": {
            "text": "Cosmetic Dentist"
          }
        },
        {
          "type": "credential",
          "settings": {
            "text": "Creator of the 7-Point Protocol"
          }
        }
      ]
    }
  ]
}
{% endschema %}
