<style>
    .policy-section {
      display: flex;
      flex-direction: column;
      gap: 60px;
    }
    .main-header {
      display: flex;
      flex-direction: column;
      gap: 16px;
      justify-content: center;
      align-items: center;
      text-align: center;
    }
    .update-parts {
      display: flex;
      gap: 16px;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
    }

    @media screen and (max-width: 400px) {
      .update-parts {
        gap: 8px;
      }
    }
  .content-container ul {
    list-style: disc;
  padding-left: 20px;
  }
    .content-container h2,
    .content-container h2 span {
      font-size: clamp(20px, 3.4vw, 28px);
      font-family: var(--display);
      font-weight: 600;
      letter-spacing: -0.02em;
      color: var(--ink);
      line-height: 1.08;
      margin-bottom: 20px;
    }
    .content-container h3,
    .content-container h3 span {
      font-size: clamp(18px, 2.6vw, 24px);
      font-family: var(--display);
      font-weight: 600;
      font-size: 20px;
      color: var(--ink);
      letter-spacing: -0.01em;
      margin-bottom: 8px;
    }
    .content-container h4 {
      font-size: clamp(17px, 1.4vw, 20px);
    }
    .content-container h5. .content-container h5 span {
      font-family: var(--display);
      font-weight: 600;
      font-size: 14.5px;
      color: var(--ink);
      margin-bottom: 20px;
    }
    .content-container h6 {
    }
    .content-container p,
    .content-container span {
      display: block;
      font-size: 15px;
      color: var(--ink-2);
      line-height: 1.55;
      margin-bottom: 20px;
    }
    .content-container a {
      display: inline-block;
      font-size: 15px;
      color: var(--navy);
      line-height: 1.55;
      text-decoration: underline;
    }
    .content-container strong {
      color: var(--navy);
    }
</style>

{% assign effective_date = page.metafields.custom.effective_date.value %}
{% assign last_updated = page.metafields.custom.last_updated.value %}

<section>
  <div class="wrap policy-section">
    <div class="main-header">
      <h1 class="main-tile display" style="text-transform: uppercase;">{{ page.title }}</h1>
      <div class="update-parts">
        <div class="update-part update-part-1 price-fine">
          <p>
            Effective Date: <span> {{ effective_date | date: '%B %d, %Y' }}</span>
          </p>
        </div>

        <div class="update-part update-part-2 price-fine">
          <p>
            Last Updated: <span> {{ last_updated | date: '%B %d, %Y' }}</span>
          </p>
        </div>
      </div>
    </div>

    <div class="content-container">
      {{ page.content }}
    </div>
  </div>
</section>
