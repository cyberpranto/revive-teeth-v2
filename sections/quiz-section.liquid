<div class="quiz-wrapper">
  <div
    class="octane-ai-quiz "
    data-quiz-id="CLqI8ayPPOEs7tTY"
    data-embed-type="fullpage"
    data-mobile-height="600px"
    data-desktop-height="600px"
    style="min-height:600px"
  >
    <div style="position: relative; width: 100%; height: 100%; min-height: 200px;" id="octane-loading-spinner-outer">
      <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; justify-content: center; align-items: center">
        <div style="width: 50px; height: 50px;">
          <img
            style="border: none"
            id="octane-loading-spinner-img"
            src="data:image/svg+xml;base64,"
            alt="Loading..."
            width="100%"
            height="100%"
          >
        </div>
      </div>
    </div>
  </div>
  <script src="https://app.octaneai.com/kz8jedy05hhkuuz3/quiz.js" defer></script>
 <script>
    document.addEventListener('octane.quiz.completed', async function (event) {
      if (sessionStorage.getItem('quiz_session')) {
        return;
      }
      try {
        console.log('Quiz completed!', event.detail);

        const response = await fetch('https://quiz-funnel-worker.quiz-funnel-worker.workers.dev/session', {
          method: 'POST',
        });

        if (!response.ok) {
          throw new Error('Failed to create session');
        }

        const data = await response.json();

        if (!data.success) {
          throw new Error('Session creation failed');
        }

        sessionStorage.setItem('quiz_session', data.session);

        console.log('Quiz Session:', data.session);
      } catch (error) {
        console.error('Quiz Session Error:', error);
      }
    });
  </script> 
</div>
