<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% comment %}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload only the critical font variant (base weight)
      3. Additional variants load on-demand via @font-face
    {% endcomment %}
    {% comment %} {% unless settings.type_primary_font.system? %} {% endcomment %}
      {% comment %} <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin> {% endcomment %}

      {% comment %} Preload the base font variant for initial page render {% endcomment %}
      {% comment %} {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }} {% endcomment %}
    {% comment %} {% endunless %} {% endcomment %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'base.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>
  <body>
    {% sections 'header-group' %}

    {{ content_for_layout }}

    {% sections 'footer-group' %}

    {% comment %} {% render 'quiz-modal' %} {% endcomment %}
    {% comment %} {% render 'exit-intent-modal' %} {% endcomment %}

    {% comment %} {% render 'sticky-bars' %} {% endcomment %}
     {% render 'quiz-modal' %}
     {% render 'exit-modal' %}

    <script src="{{ 'app.js' | asset_url }}" defer></script>
  </body>
</html>
